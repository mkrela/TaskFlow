@page "/login"
@using System.Text.Json
@using TaskFlow.Client.Models
@using TaskFlow.Client.Services
@inject IAuthService AuthService
@inject ProjectApi ProjectApi

<input @bind="username" placeholder="username" />
<input @bind="password" placeholder="password" type="password" />
<button @onclick="LoginAndCreate">Login & Create</button>

@code {
    private string username = "test";
    private string password = "test";

    private async Task LoginAndCreate()
    {
        // Utiliser le nouveau AuthService
        var loginSuccess = await AuthService.LoginAsync(username, password);

        if (!loginSuccess)
        {
            Console.WriteLine("Login failed");
            return;
        }

        Console.WriteLine("Login successful");

        try
        {
            var req = new CreateProjectRequest("Projet depuis UI", Guid.Empty);
            var created = await ProjectApi.CreateAsync(req);
            Console.WriteLine($"Créé {created.Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating project: {ex.Message}");
        }
    }
}
